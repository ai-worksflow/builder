# Compose application-image build inputs. Every base must be an immutable image
# reference; the Dockerfiles reject tags before dependency installation.
FRONTEND_NODE_IMAGE=node@sha256:16e22a550f3863206a3f701448c45f7912c6896a62de43add43bb9c86130c3e2
BACKEND_GO_IMAGE=golang@sha256:1a478681b671001b7f029f94b5016aed984a23ad99c707f6a0ab6563860ae2f3
BACKEND_RUNTIME_IMAGE=alpine@sha256:d9e853e87e55526f6b2917df91a2115c36dd7c696a35be12163d44e6e2a4b6bc

# Runtime
APP_ENV=development
SERVICE_NAME=worksflow-api
LOG_LEVEL=info
LOG_FORMAT=json

# HTTP
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=5m
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s
HTTP_MAX_HEADER_BYTES=1048576
HTTP_MAX_JSON_BODY_BYTES=1048576
HTTP_TRUSTED_PROXIES=

# Browser security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,Idempotency-Key,If-Match,X-CSRF-Token,X-Request-ID,X-Sandbox-Session-Epoch,X-Expected-Candidate-ID,X-Candidate-Version,X-Candidate-Journal-Sequence,X-Writer-Lease-Epoch,X-Candidate-Tree-Hash,X-Expected-File-Hash,X-File-Mode
CORS_EXPOSED_HEADERS=ETag,Idempotency-Replayed,Retry-After,X-Request-ID,Content-Disposition,Digest,X-Archive-File-Count,X-Archive-Redaction-Count,X-Command-ETag,X-Command-Location,X-Sandbox-Session-ETag,X-Sandbox-Session-Epoch,X-Candidate-ID,X-Candidate-Version,X-Candidate-Journal-Sequence,X-Writer-Lease-Epoch,X-Candidate-Tree-Hash,X-Candidate-Tree-ETag,X-Content-Hash,X-File-Mode,X-Content-Object-Hash,X-File-Exists,X-Byte-Size,X-Patch-Content-Hash,X-Agent-Attempt-State,X-Agent-Fence-Epoch
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=12h
SECURITY_ENABLE_HSTS=false

# Session cookies, CSRF and password hashing
SESSION_TTL=168h
SESSION_CACHE_PREFIX=worksflow:session:
SESSION_COOKIE_NAME=worksflow_session
SESSION_COOKIE_PATH=/
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
CSRF_COOKIE_NAME=worksflow_csrf
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_BYTES=32
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2
ARGON2_SALT_BYTES=16
ARGON2_KEY_BYTES=32

# 32-byte platform key for encrypted data-runtime/GitHub secrets and keyed auth
# replay receipts. Auth receipts persist only keyed digests and session IDs.
# Replace this documented development-only key in every shared environment.
PLATFORM_ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# Per-user, per-project GitHub integration (no shared process token fallback)
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_REQUEST_TIMEOUT=12s
GITHUB_CREDENTIAL_TTL=8h
GITHUB_REDIS_PREFIX=worksflow:github:credential:

# Delivery quality runs execute only fixed commands in an isolated container
# with no network, dropped capabilities, a read-only root, and bounded resources.
# Images use --pull=never; pre-provision the configured images on the runtime.
DELIVERY_SANDBOX_RUNTIME=docker
DELIVERY_SANDBOX_HOST=
# Development tags are convenient but not reproducible. Staging/production
# must set immutable image@sha256:<64 lowercase hex> references.
DELIVERY_SANDBOX_NODE_IMAGE=node:22-alpine
DELIVERY_SANDBOX_GO_IMAGE=golang:1.22-alpine
DELIVERY_SANDBOX_TIMEOUT=2m
DELIVERY_SANDBOX_OUTPUT_MAX_BYTES=1048576
DELIVERY_SANDBOX_MEMORY=512m
DELIVERY_SANDBOX_CPUS=1.0
DELIVERY_SANDBOX_PIDS=128
# The resolver is the only quality stage with network access. It receives a
# directory containing only package.json/package-lock.json or go.mod/go.sum.
# Never set the resolver network to host; do not add GOPROXY fallbacks/direct.
DELIVERY_RESOLVER_NETWORK=bridge
DELIVERY_RESOLVER_NPM_REGISTRY=https://registry.npmjs.org
DELIVERY_RESOLVER_GO_PROXY=https://proxy.golang.org
DELIVERY_RESOLVER_GO_SUMDB=sum.golang.org
DELIVERY_RESOLVER_TIMEOUT=3m
DELIVERY_RESOLVER_OUTPUT_MAX_BYTES=1048576
DELIVERY_RESOLVER_MEMORY=512m
DELIVERY_RESOLVER_CPUS=1.0
DELIVERY_RESOLVER_PIDS=128
# A TCP/DinD daemon requires this absolute path to be mounted at the identical
# location in both API and daemon containers.
DELIVERY_QUALITY_TEMP_ROOT=

# Local immutable preview/production provider. Use a durable volume in shared
# environments. The public base URL must be absolute when the public data
# runtime is enabled so deployment capabilities can bind an exact browser Origin.
DELIVERY_PUBLISH_ROOT=./var/published
DELIVERY_PUBLISH_BASE_URL=http://localhost:8080/published

# Governed Release Controller v3 handoff. The worker is deliberately disabled
# until every exact controller identity and trust value has been reviewed.
# Shared environments must inject the token through their secret manager.
RELEASE_DELIVERY_WORKER_ENABLED=false
RELEASE_DELIVERY_WORKER_ID=
RELEASE_DELIVERY_CONTROLLER_URL=
RELEASE_DELIVERY_CONTROLLER_TOKEN=
RELEASE_DELIVERY_CONTROLLER_ID=
RELEASE_DELIVERY_CONTROLLER_VERSION=
RELEASE_DELIVERY_CONTROLLER_PROTOCOL=worksflow.release-delivery/v3
RELEASE_DELIVERY_CONTROLLER_TRUST_KEY_DIGEST=
RELEASE_DELIVERY_LEASE_DURATION=5m
RELEASE_DELIVERY_POLL_INTERVAL=1s
RELEASE_DELIVERY_RECONCILE_DELAY=5s
RELEASE_DELIVERY_REQUEST_TIMEOUT=2m
RELEASE_DELIVERY_RESPONSE_MAX_BYTES=1048576

# Interactive project sandbox. Enabling it requires a previously admitted,
# digest-pinned Runner image already present on the selected daemon.
SANDBOX_ENABLED=false
SANDBOX_RUNNER_IMAGE=
SANDBOX_RUNTIME=docker
SANDBOX_DAEMON_HOST=
SANDBOX_WORKSPACE_ROOT=/var/lib/worksflow/sandboxes
SANDBOX_GATEWAY_NETWORK=bridge
SANDBOX_GATEWAY_BIND_ADDRESS=127.0.0.1
SANDBOX_PREVIEW_DIAL_HOST=127.0.0.1
SANDBOX_PREVIEW_PUBLIC_ORIGIN=http://preview.localhost:8080
SANDBOX_PREVIEW_TICKET_TTL=15m
SANDBOX_PREVIEW_PROBE_TIMEOUT=750ms
SANDBOX_STARTUP_TIMEOUT=2m
SANDBOX_COMMAND_TIMEOUT=30s
SANDBOX_RUNTIME_OUTPUT_MAX_BYTES=1048576
SANDBOX_CPU_MILLIS=2000
SANDBOX_MEMORY_BYTES=4294967296
SANDBOX_WORKSPACE_BYTES=10737418240
SANDBOX_PID_LIMIT=256
SANDBOX_PREVIEW_PORT_LIMIT=3
SANDBOX_IDLE_HIBERNATE_AFTER=30m
SANDBOX_MAX_RUNTIME=8h
SANDBOX_LIFECYCLE_WORKER_ID=
SANDBOX_LIFECYCLE_POLL_INTERVAL=5s
SANDBOX_LIFECYCLE_LEASE_DURATION=15m
SANDBOX_LIFECYCLE_RETRY_DELAY=30s
SANDBOX_CONNECTION_TICKET_TTL=30s
SANDBOX_STREAM_MAX_EVENTS=4096
SANDBOX_STREAM_RETENTION=24h
SANDBOX_REDIS_PREFIX=worksflow:sandbox:

# Exact language-server profiles bind to ready SandboxSession workspaces.
# Shared staging/production environments require WSS/TLS and exact origins.
LSP_ENABLED=false
LSP_RUNTIME_BINARY=/usr/bin/docker
LSP_DAEMON_HOST=
LSP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LSP_REQUIRE_TLS=false
LSP_TICKET_TTL=20s
LSP_BIND_TIMEOUT=5s
LSP_WRITE_WAIT=2s
LSP_COMMAND_TIMEOUT=30s
LSP_CLI_OUTPUT_MAX_BYTES=1048576
LSP_REDIS_PREFIX=worksflow:sandbox:lsp:
LSP_RATE_REFILL_PER_SECOND=30
LSP_RATE_BURST=60
LSP_PRELOAD_IMAGES=

# Independent Candidate verification worker. The workspace path must be mounted
# at the same absolute path in the API and its Docker/Podman daemon.
VERIFICATION_WORKER_ENABLED=false
VERIFICATION_WORKER_ID=
VERIFICATION_RUNTIME=docker
VERIFICATION_DAEMON_HOST=
VERIFICATION_WORKSPACE_ROOT=/var/lib/worksflow/verification
VERIFICATION_MEMORY=1g
VERIFICATION_CPUS=1.0
VERIFICATION_PIDS=256
VERIFICATION_OUTPUT_MAX_BYTES=1048576
VERIFICATION_TEMP_BYTES=536870912
VERIFICATION_POLL_INTERVAL=1s
VERIFICATION_LEASE_DURATION=2m
VERIFICATION_HEARTBEAT=30s

# Real Codex Agent control/worker. The current qualified implementation is
# exactly codex-cli + OpenAI; alternative labels are rejected so immutable
# evidence cannot claim a provider or adapter that did not run. Worker mode
# also requires OPENAI_API_KEY and HTTP_WRITE_TIMEOUT >= AGENT_WALL_TIME + 30s.
AGENT_ENABLED=false
AGENT_WORKER_ENABLED=false
AGENT_WORKER_ID=
AGENT_EXECUTOR_PROFILE_ID=codex-default
AGENT_EXECUTOR_ADAPTER=codex-cli
AGENT_EXECUTOR_PROVIDER=openai
AGENT_EXECUTOR_MODEL=gpt-5
AGENT_RUNNER_IMAGE=
AGENT_RUNTIME=docker
AGENT_DAEMON_HOST=
AGENT_WORKTREE_ROOT=/var/lib/worksflow/agent-worktrees
AGENT_RUNNER_NETWORK=worksflow-agent-model
AGENT_RUNNER_MEMORY=4g
AGENT_RUNNER_CPUS=2.0
AGENT_RUNNER_PIDS=256
AGENT_RUNNER_OUTPUT_MAX_BYTES=8388608
AGENT_MODEL_GATEWAY_BASE_URL=
AGENT_MODEL_GATEWAY_REDIS_PREFIX=worksflow:agent:model:
AGENT_MODEL_POLICY_HASH=
AGENT_PARAMETERS_HASH=
AGENT_PROMPT_HASH=
AGENT_OUTPUT_SCHEMA_HASH=
AGENT_TOOLCHAIN_HASH=
AGENT_ALLOWED_TOOLS=file.read,file.write,file.search,shell.exec,diagnostic.read
AGENT_WALL_TIME=4m
AGENT_MAX_INPUT_TOKENS=200000
AGENT_MAX_OUTPUT_TOKENS=50000
AGENT_MAX_COMMANDS=200
AGENT_MAX_LOG_BYTES=8388608
AGENT_MAX_PATCH_BYTES=16777216
AGENT_MAX_CONTEXT_FILES=256
AGENT_CLAIM_BATCH=10
AGENT_POLL_INTERVAL=1s
AGENT_LEASE_DURATION=2m
AGENT_HEARTBEAT=30s
# Compose-only timeout shared by the two path-confined Model Relay hops.
AGENT_MODEL_RELAY_REQUEST_TIMEOUT=8h1m

# Infrastructure startup and readiness
DEPENDENCY_CONNECT_TIMEOUT=10s
DEPENDENCY_READINESS_TIMEOUT=2s

# Non-PostgreSQL startup mutations default to true in development/test and
# false in production. Production should provision these resources separately.
STARTUP_ENSURE_MONGO_INDEXES=true
STARTUP_ENSURE_NATS_STREAM=true
STARTUP_TIMEOUT=30s
CONTENT_MAX_BYTES=16777216
CONTENT_RECONCILE_ENABLED=true
CONTENT_RECONCILE_INTERVAL=1m
CONTENT_PENDING_GRACE=5m
CONTENT_ORPHAN_TTL=24h
CONTENT_RECONCILE_BATCH=100

# Transactional outbox publisher
OUTBOX_ENABLED=true
OUTBOX_BATCH_SIZE=50
OUTBOX_POLL_INTERVAL=500ms
OUTBOX_CLAIM_TTL=30s
OUTBOX_MAX_ATTEMPTS=20
OUTBOX_PUBLISH_WAIT=5s

# Database-backed mutation deduplication
IDEMPOTENCY_TTL=24h
IDEMPOTENCY_LOCK_TTL=2m
IDEMPOTENCY_MAX_RESPONSE_BYTES=8388608

# Structured AI generation. Leave OPENAI_API_KEY empty to keep AI routes
# installed but fail closed with an explicit not-configured response.
AI_PROVIDER=openai
OPENAI_API_KEY=
# Base host is expanded to /v1/responses. The explicit URL overrides it.
OPENAI_BASE_URL=https://api.openai.com
OPENAI_RESPONSES_URL=
OPENAI_DEFAULT_MODEL=gpt-5
AI_TIMEOUT=12m
AI_MAX_INPUT_BYTES=4194304
AI_MAX_OUTPUT_BYTES=16777216
AI_MAX_RETRIES=0
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# Durable workflow worker
WORKFLOW_WORKER_ENABLED=true
WORKFLOW_WORKER_ID=
WORKFLOW_POLL_INTERVAL=500ms
WORKFLOW_LEASE_DURATION=2m
WORKFLOW_HEARTBEAT=30s

# PostgreSQL / GORM API credentials. The API never applies schema migrations.
POSTGRES_DSN=postgres://worksflow:worksflow@localhost:5432/worksflow?sslmode=disable
POSTGRES_SCHEMA=public
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m
POSTGRES_CONN_MAX_IDLE_TIME=5m

# Standalone cmd/migrate credentials. Use a separate migration owner in shared
# environments; do not copy its DDL authority into POSTGRES_DSN.
WORKSFLOW_MIGRATION_POSTGRES_DSN=postgres://worksflow:worksflow@localhost:5432/worksflow?sslmode=disable
WORKSFLOW_MIGRATION_POSTGRES_SCHEMA=public
WORKSFLOW_MIGRATION_TIMEOUT=30m

# One-shot exact-tree index retention operator. This DSN must identify a
# distinct LOGIN that inherits only worksflow_repository_index_gc_operator.
# Schema and stable run ID are deliberately empty so maintenance fails closed
# until an operator supplies the reviewed deployment identity and invocation.
WORKSFLOW_REPOSITORY_INDEX_GC_POSTGRES_DSN=
WORKSFLOW_REPOSITORY_INDEX_GC_POSTGRES_SCHEMA=
WORKSFLOW_REPOSITORY_INDEX_GC_RUN_ID=
WORKSFLOW_REPOSITORY_INDEX_GC_RETENTION=720h
WORKSFLOW_REPOSITORY_INDEX_GC_KEEP_PER_PROJECT=8
WORKSFLOW_REPOSITORY_INDEX_GC_BATCH_SIZE=25
WORKSFLOW_REPOSITORY_INDEX_GC_CAPABILITY_TTL=10m
WORKSFLOW_REPOSITORY_INDEX_GC_TIMEOUT=5m

# Redis
REDIS_ADDRESS=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_USE_TLS=false

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=worksflow

# NATS with JetStream enabled
NATS_URL=nats://localhost:4222
NATS_CLIENT_NAME=worksflow-api

# WebSocket. Anonymous access is for local development only. Production should
# leave it false and inject a realtime.Authenticator from the application auth layer.
WS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WS_ALLOW_ANONYMOUS=false
WS_AUTH_TIMEOUT=10s
WS_WRITE_WAIT=10s
WS_PONG_WAIT=60s
WS_PING_PERIOD=50s
WS_MAX_MESSAGE_BYTES=65536
WS_SEND_BUFFER=64
WS_MAX_SUBSCRIPTIONS=128
WS_MAX_REPLAY_EVENTS=50
