{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worksflow.dev/schemas/api-contract-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "openapi", "info", "paths"],
  "properties": {
    "schemaVersion": {"const": "api-contract/v2"},
    "openapi": {"type": "string", "pattern": "^3\\.1\\.[0-9]+$"},
    "info": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "version"],
      "properties": {
        "title": {"type": "string", "minLength": 1, "maxLength": 200},
        "version": {"type": "string", "minLength": 1, "maxLength": 80},
        "description": {"type": "string", "maxLength": 4000}
      }
    },
    "servers": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url"],
        "properties": {
          "url": {"type": "string", "minLength": 1, "maxLength": 500},
          "description": {"type": "string", "maxLength": 500}
        }
      }
    },
    "paths": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {"pattern": "^/"},
      "additionalProperties": {"$ref": "#/$defs/pathItem"}
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schemas": {"type": "object", "additionalProperties": {"$ref": "#/$defs/schemaValue"}},
        "responses": {"type": "object", "additionalProperties": {"$ref": "#/$defs/responseObject"}},
        "securitySchemes": {"type": "object", "additionalProperties": {"type": "object"}}
      }
    }
  },
  "$defs": {
    "schemaValue": {"type": ["object", "boolean"]},
    "referenceObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$ref"],
      "properties": {
        "$ref": {"type": "string", "pattern": "^#/"},
        "summary": {"type": "string", "maxLength": 500},
        "description": {"type": "string", "maxLength": 4000}
      }
    },
    "responseObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": {"type": "string", "minLength": 1, "maxLength": 4000},
        "headers": {"type": "object"},
        "content": {"type": "object"},
        "links": {"type": "object"}
      }
    },
    "responseOrReference": {
      "oneOf": [
        {"$ref": "#/$defs/responseObject"},
        {"$ref": "#/$defs/referenceObject"}
      ]
    },
    "pathItem": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "get": {"$ref": "#/$defs/operation"},
        "post": {"$ref": "#/$defs/operation"},
        "put": {"$ref": "#/$defs/operation"},
        "patch": {"$ref": "#/$defs/operation"},
        "delete": {"$ref": "#/$defs/operation"},
        "head": {"$ref": "#/$defs/operation"},
        "options": {"$ref": "#/$defs/operation"},
        "parameters": {"type": "array", "items": {"type": "object"}}
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationId", "responses"],
      "properties": {
        "operationId": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"},
        "summary": {"type": "string", "maxLength": 500},
        "description": {"type": "string", "maxLength": 4000},
        "tags": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "parameters": {"type": "array", "items": {"type": "object"}},
        "requestBody": {"type": "object"},
        "responses": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {"pattern": "^(default|[1-5][0-9][0-9]|[1-5]XX)$"},
          "additionalProperties": {"$ref": "#/$defs/responseOrReference"}
        },
        "security": {"type": "array", "items": {"type": "object"}},
        "deprecated": {"type": "boolean"}
      }
    }
  }
}
