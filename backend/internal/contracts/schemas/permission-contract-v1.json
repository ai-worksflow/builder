{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worksflow.dev/schemas/permission-contract-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "identity", "tenant", "roles", "policies"],
  "properties": {
    "schemaVersion": {"const": "permission-contract/v1"},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subjectClaim", "authentication"],
      "properties": {
        "subjectClaim": {"type": "string", "minLength": 1, "maxLength": 120},
        "authentication": {"enum": ["session", "bearer", "oidc"]}
      }
    },
    "tenant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "claim"],
      "properties": {
        "mode": {"enum": ["single", "project", "organization"]},
        "claim": {"type": "string", "minLength": 1, "maxLength": 120}
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"},
          "description": {"type": "string", "maxLength": 1000}
        }
      }
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "roles", "resource", "actions", "tenantScoped", "effect"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"},
          "roles": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
          "resource": {"type": "string", "minLength": 1, "maxLength": 200},
          "actions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "tenantScoped": {"type": "boolean"},
          "effect": {"const": "allow"}
        }
      }
    }
  }
}
