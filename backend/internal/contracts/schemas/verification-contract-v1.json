{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worksflow.dev/schemas/verification-contract-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "oracles"],
  "properties": {
    "schemaVersion": {"const": "verification-contract/v1"},
    "oracles": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "acceptanceCriterionIds", "kind", "target", "blocking"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"},
          "acceptanceCriterionIds": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "kind": {"enum": ["unit", "contract", "integration", "browser", "accessibility", "security", "health"]},
          "target": {"type": "string", "minLength": 1, "maxLength": 300},
          "commandId": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,79}$"},
          "blocking": {"const": true}
        },
        "allOf": [
          {"if": {"properties": {"kind": {"enum": ["unit", "contract", "integration", "browser", "accessibility", "security"]}}}, "then": {"required": ["commandId"]}}
        ]
      }
    }
  }
}
